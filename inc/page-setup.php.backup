/**
 * Page Setup Utility
 *
 * Creates all necessary pages for the theme with one click.
 *
 * @package HID_HOV_Theme
 */

// If this file is called directly, abort.
if (!defined('ABSPATH')) {
    exit;
}

/**
 * Helper function to get page by title (replaces deprecated get_page_by_title)
 *
 * @param string $title Page title
 * @return WP_Post|null Page object or null if not found
 */
function hid_hov_get_page_by_title($title)
{
    $pages = get_posts(array(
        'post_type' => 'page',
        'post_status' => 'publish',
        'title' => $title,
        'posts_per_page' => 1,
        'no_found_rows' => true,
        'ignore_sticky_posts' => true,
        'suppress_filters' => false,
    ));

    return !empty($pages) ? $pages[0] : null;
}

/**
 * Add Page Setup submenu
 */
function hid_hov_add_page_setup_menu()
{
    add_submenu_page(
        'hid-commerce',
        __('Page Setup', 'hid-hov-theme'),
        __('Page Setup', 'hid-hov-theme'),
        'manage_options',
        'hid-commerce-page-setup',
        'hid_hov_page_setup_page'
    );
}
add_action('admin_menu', 'hid_hov_add_page_setup_menu', 100);

/**
 * Page Setup page content
 */
function hid_hov_page_setup_page()
{
    // Check user capabilities
    if (!current_user_can('manage_options')) {
        wp_die(__('You do not have sufficient permissions to access this page.', 'hid-hov-theme'));
    }

    // Handle form submission for pages
    if (isset($_POST['hid_create_pages']) && check_admin_referer('hid_create_pages_nonce')) {
        $result = hid_hov_create_all_pages();

        if ($result['success']) {
            echo '<div class="notice notice-success is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
            if (!empty($result['details'])) {
                echo '<div class="notice notice-info"><ul>';
                foreach ($result['details'] as $detail) {
                    echo '<li>' . esc_html($detail) . '</li>';
                }
                echo '</ul></div>';
            }
        } else {
            echo '<div class="notice notice-error is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
        }
    }

    // Handle form submission for menus
    if (isset($_POST['hid_create_menus']) && check_admin_referer('hid_create_menus_nonce')) {
        $result = hid_hov_create_all_menus();

        if ($result['success']) {
            echo '<div class="notice notice-success is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
            if (!empty($result['details'])) {
                echo '<div class="notice notice-info"><ul>';
                foreach ($result['details'] as $detail) {
                    echo '<li>' . esc_html($detail) . '</li>';
                }
                echo '</ul></div>';
            }
        } else {
            echo '<div class="notice notice-error is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
        }
    }

    // Handle form submission for seed products
    if (isset($_POST['hid_create_seed_products']) && check_admin_referer('hid_create_seed_products_nonce')) {
        set_time_limit(300); // Increase time limit for bulk operations
        $result = hid_hov_create_seed_products();

        if ($result['success']) {
            echo '<div class="notice notice-success is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
            if (!empty($result['details'])) {
                echo '<div class="notice notice-info"><ul>';
                foreach ($result['details'] as $detail) {
                    echo '<li>' . esc_html($detail) . '</li>';
                }
                echo '</ul></div>';
            }
        } else {
            echo '<div class="notice notice-error is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
        }
    }

    // Handle form submission for deleting seed products
    if (isset($_POST['hid_delete_seed_products']) && check_admin_referer('hid_delete_seed_products_nonce')) {
        set_time_limit(300); // Increase time limit for bulk operations
        $result = hid_hov_delete_seed_products();

        if ($result['success']) {
            echo '<div class="notice notice-success is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
            if (!empty($result['details'])) {
                echo '<div class="notice notice-info"><ul>';
                foreach ($result['details'] as $detail) {
                    echo '<li>' . esc_html($detail) . '</li>';
                }
                echo '</ul></div>';
            }
        } else {
            echo '<div class="notice notice-error is-dismissible"><p>' . esc_html($result['message']) . '</p></div>';
        }
    }

?>
    <div class="wrap">
        <h1><?php _e('Theme Page Setup', 'hid-hov-theme'); ?></h1>

        <div class="card" style="max-width: 800px;">
            <h2><?php _e('Create Theme Pages', 'hid-hov-theme'); ?></h2>
            <p><?php _e('This tool will create all necessary pages for your HID HOV Theme. If pages with the same titles already exist, they will be deleted and recreated with the correct templates and content.', 'hid-hov-theme'); ?></p>

